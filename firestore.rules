rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is a staff member
    function isStaffMember() {
      return isAuthenticated() && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    // Businesses / Enterprise Workspaces
    match /businesses/{businessId} {
      allow read: if true; // Public booking portals & walk-in queue pages need branding, logo, services
      allow create, update, delete: if isAuthenticated() && request.auth.uid == businessId;
    }

    // Queues
    match /queues/{queueId} {
      allow read: if true; // Customers need to see live waiting counts, token numbers, status, and announcements
      allow create, delete: if isAuthenticated() && (
        request.auth.uid == request.resource.data.businessId || 
        request.auth.uid == request.resource.data.locationId ||
        request.auth.uid == resource.data.businessId || 
        request.auth.uid == resource.data.locationId
      );
      // Allow updates by business owner or staff, OR allow walk-in customers (unauthenticated or guest) to only join/leave line
      allow update: if (isAuthenticated() && (
        request.auth.uid == resource.data.businessId || 
        request.auth.uid == resource.data.locationId ||
        isStaffMember()
      )) || (
        // Unauthenticated / Walk-in customers joining or leaving can only modify entries and waitingCount
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['entries', 'waitingCount'])
      );
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow read: if true; // Availability calculation and customers checking status
      allow create: if true; // Guests booking appointments online
      // Allow updates by authorized staff/owners, OR guests checking in VIP fast-pass (updating status to 'arrived' or 'cancelled')
      allow update: if isAuthenticated() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancellationReason', 'cancellationSmsSent'])
      );
      allow delete: if isAuthenticated();
    }

    // Customers (CRM Logs)
    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow create, update: if true; // Walk-in customers and staff save records when joining or being called
      allow delete: if isAuthenticated();
    }

    // Staff Profiles
    match /staff/{staffId} {
      allow read: if true; // For route verification and team profile display
      allow write: if isAuthenticated() && (
        request.auth.uid == staffId || 
        request.auth.uid == request.resource.data.businessId || 
        request.auth.uid == resource.data.businessId
      );
    }

    // Staff Invites
    match /staffInvites/{inviteId} {
      allow read: if true; // When staff clicks invite link
      allow write: if isAuthenticated();
    }

    // System Health / Cron Metrics (written by server-side cron, read by admin dashboard)
    match /systemHealth/{docId} {
      allow read: if isAuthenticated(); // Only logged-in admins can read cron health metrics
      allow write: if false; // Never allow client writes — only server (Firebase Admin SDK) or cron writes these
    }
  }
}
